  "keyFeatures": [
    "One-command session tracking with cs run — handles full lifecycle automatically",
    "Local HTTP proxy that intercepts Anthropic and OpenAI API calls and logs them automatically",
    "OpenClaw skill and Claude Code hook integration for zero-touch agent tracking",
    "Web dashboard at localhost:3737 with cost charts, model breakdown, and session analytics",
    "Budget alerts with per-session and daily spend limits, alarm mode with browser notifications",
    "Drop-in Node.js SDK extensions: TrackedOpenAI, TrackedAnthropic, TrackedGoogleAI",
    "Built-in pricing for 42+ models including Claude, OpenAI GPT, Codex, DeepSeek, and Cohere",
    "Git commit tracking and filesystem watcher for automatic file change detection",
    "100% local SQLite storage — no telemetry, no cloud sync, no API key storage",
    "JSON output on every command for machine-readable agent integrations",
    "Pro tier: Spend Firewall, runaway agent alerts, shareable stats card, CSV export, heatmaps"
  ],
  "publicApiSurface": [
    "cs start <description> [--close-stale] [--resume] [--json]",
    "cs end [-n notes] [-s id] [--json]",
    "cs run [--name] [--port] [--no-proxy] <command>",
    "cs proxy [--port] [--session]",
    "cs status [-s id] [--json]",
    "cs show [id] [--files] [--commits] [--json]",
    "cs list [-l limit] [--json]",
    "cs stats [--json]",
    "cs log-ai -p <provider> -m <model> [--prompt-tokens] [--completion-tokens] [-t] [-c] [-s id] [--json]",
    "cs note <message> [-s id] [--json]",
    "cs recover [--max-age hours]",
    "cs export [--format json|csv] [--limit n]",
    "cs dashboard [--port] [--host] [--no-open] [--json]",
    "cs budget [--daily amount] [--session amount]",
    "cs pricing list",
    "cs pricing set <model> <in> <out> [--provider]",
    "cs pricing reset",
    "cs mcp",
    "cs auto-log [--provider] [--model] [--agent]",
    "AgentSession class (costhq/agents)",
    "runAgentSession helper (costhq/agents)",
    "BudgetExceededError (costhq/agents)",
    "TrackedOpenAI class (costhq/extensions)",
    "TrackedAnthropic class (costhq/extensions)",
    "TrackedGoogleAI class (costhq/extensions)",
    "trackedGPT wrapper (costhq/wrappers)",
    "trackedClaude wrapper (costhq/wrappers)",
    "withTracking middleware (costhq/middleware)",
    "BatchTracker class (costhq/middleware)",
    "createTrackedClient (costhq/middleware)"
  ]
