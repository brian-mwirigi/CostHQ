{
  "name": "costhq",
  "version": "4.0.0",
  "description": "CostHQ: Track AI agent & coding session costs — files, commits, tokens. Free & Pro tiers available.",
  "homepage": "https://costhq.mintlify.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brian-mwirigi/CostHQ.git"
  },
  "bugs": {
    "url": "https://github.com/brian-mwirigi/CostHQ/issues"
  },
  "funding": "https://github.com/sponsors/brian-mwirigi",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "costhq": "dist/src/index.js",
    "cs": "dist/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    },
    "./agents": {
      "types": "./dist/src/agents.d.ts",
      "import": "./dist/src/agents.js",
      "require": "./dist/src/agents.js"
    },
    "./wrappers": {
      "types": "./dist/src/wrappers.d.ts",
      "import": "./dist/src/wrappers.js",
      "require": "./dist/src/wrappers.js"
    },
    "./middleware": {
      "types": "./dist/src/middleware.d.ts",
      "import": "./dist/src/middleware.js",
      "require": "./dist/src/middleware.js"
    },
    "./extensions": {
      "types": "./dist/src/extensions.d.ts",
      "import": "./dist/src/extensions.js",
      "require": "./dist/src/extensions.js"
    }
  },
  "scripts": {
    "build": "tsc && npx vite build --config dashboard/vite.config.ts && node scripts/minify-pro.js",
    "build:cli": "tsc && node scripts/minify-pro.js",
    "build:dashboard": "npx vite build --config dashboard/vite.config.ts",
    "dev": "tsx src/index.ts",
    "dev:dashboard": "npx vite --config dashboard/vite.config.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "release": "node scripts/release.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "screenshots": "node scripts/capture-screenshots.js",
    "screenshots:setup": "bash scripts/setup-demo-data.sh || scripts\\setup-demo-data.bat"
  },
  "keywords": [
    "ai",
    "coding",
    "session",
    "tracker",
    "ai-agent",
    "openclaw",
    "claude-code",
    "cost-tracking",
    "token-tracking",
    "git",
    "cli",
    "agents",
    "budget",
    "observability"
  ],
  "author": "Brian Mwirigi",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@inquirer/prompts": "^8.4.1",
    "@supabase/supabase-js": "^2.106.1",
    "better-sqlite3": "^12.9.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "date-fns": "^3.0.6",
    "express": "^5.2.1",
    "simple-git": "^3.22.0"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.6",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vercel/ncc": "^0.38.4",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.1.7",
    "puppeteer": "^22.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "supertest": "^7.2.2",
    "terser": "^5.48.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
